    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "👋 <b>Привет, {{ $json.username }}!</b>\n\nЯ — твой умный AI-ассистент с суперспособностями:\n\n🌐 <b>Поиск в интернете</b> — найду актуальную информацию\n🧠 <b>Память разговора</b> — помню весь наш диалог\n🎙️ <b>Голосовые сообщения</b> — понимаю речь, отвечаю текстом\n\n💬 Напиши или надиктуй вопрос — дам точный ответ!",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "n-welcome",
      "name": "Send Welcome",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [1060, 300],
      "credentials": {
        "telegramApi": { "id": "TELEGRAM_CRED_ID", "name": "Telegram Bot" }
      }
    },
