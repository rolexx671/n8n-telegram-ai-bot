      "id": "n-webhook",
      "name": "Telegram Webhook",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [180, 400],
      "webhookId": "tg-ai-bot-v2-wh"
    },
    {
      "parameters": {
        "jsCode": "const body = $input.first().json.body || $input.first().json;\nconst message = body.message || body.edited_message;\n\nif (!message) return [{ json: { skip: true } }];\n\nconst chatId   = String(message.chat.id);\nconst userId   = message.from?.id;\nconst username = message.from?.username || message.from?.first_name || 'User';\nconst text     = message.text || '';\nconst isVoice  = !!message.voice;\nconst isStart  = text.trim() === '/start';\nconst voiceFileId = isVoice ? message.voice.file_id : null;\n\nif (!text && !isVoice) return [{ json: { skip: true } }];\n\nreturn [{\n  json: { chatId, userId, username, text, isVoice, isStart, voiceFileId, skip: false }\n}];"
      },
      "id": "n-parse",
      "name": "Parse Message",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [400, 400]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "typeValidation": "strict" },
          "conditions": [
            {
              "id": "c1",
              "leftValue": "={{ $json.skip }}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "n-skip",
      "name": "Skip Empty?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
