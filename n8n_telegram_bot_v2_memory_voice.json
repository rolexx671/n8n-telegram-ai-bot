      },
      "id": "n-tavily",
      "name": "Tavily Web Search",
      "type": "@n8n/n8n-nodes-langchain.toolTavilySearch",
      "typeVersion": 1,
      "position": [2800, 780],
      "credentials": {
        "tavilyApi": { "id": "TAVILY_CRED_ID", "name": "Tavily" }
      }
    },
    {
      "parameters": {
        "jsCode": "const agentOutput = $input.first().json;\nconst prevData = $('Set Voice Text').item?.json || $('Set Text Data').item?.json;\n\n// Получаем chatId из предыдущего контекста\nlet chatId = '';\ntry { chatId = $('Set Voice Text').item.json.chatId; } catch(e) {}\ntry { if (!chatId) chatId = $('Set Text Data').item.json.chatId; } catch(e) {}\n\n// Получаем ответ агента\nlet answer = agentOutput.output || agentOutput.text || JSON.stringify(agentOutput);\n\n// Telegram ограничение 4096 символов\nif (answer.length > 3800) {\n  answer = answer.substring(0, 3800) + '...\\n\\n_[ответ сокращён]_';\n}\n\nreturn [{ json: { chatId, answer } }];"
      },
      "id": "n-format",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2820, 580]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "={{ $json.answer }}",
        "additionalFields": { "parse_mode": "Markdown" }
      },
      "id": "n-send",
      "name": "Send Answer",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [3040, 580],
      "credentials": {
        "telegramApi": { "id": "TELEGRAM_CRED_ID", "name": "Telegram Bot" }
      }
    },
