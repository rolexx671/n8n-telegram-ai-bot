    {
      "parameters": {
        "assignments": {
          "assignments": [
            { "id": "sv1", "name": "chatId",     "value": "={{ $('Parse Message').item.json.chatId }}",    "type": "string" },
            { "id": "sv2", "name": "username",   "value": "={{ $('Parse Message').item.json.username }}",  "type": "string" },
            { "id": "sv3", "name": "chatInput",  "value": "={{ $json.text }}",                             "type": "string" },
