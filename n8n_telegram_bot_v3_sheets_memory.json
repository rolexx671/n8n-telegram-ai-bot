            { "id": "st1", "name": "chatId",     "value": "={{ $json.chatId }}",   "type": "string" },
            { "id": "st2", "name": "username",   "value": "={{ $json.username }}", "type": "string" },
            { "id": "st3", "name": "chatInput",  "value": "={{ $json.text }}",     "type": "string" },
