          "options": { "caseSensitive": true, "typeValidation": "strict" },
          "conditions": [{ "id": "c-start", "leftValue": "={{ $json.isStart }}", "rightValue": true, "operator": { "type": "boolean", "operation": "equals" } }],
          "combinator": "and"
        }
      },
      "id": "n-is-start",
      "name": "Is /start?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [780, 460]
    },
    {
      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "text": "👋 <b>Привет, {{ $json.username }}!</b>\n\nЯ — твой умный AI-ассистент:\n\n🌐 <b>Ищу в интернете</b> — актуальные данные\n🧠 <b>Постоянная память</b> — помню всё в Google Sheets\n🎙️ <b>Голосовые сообщения</b> — говори, отвечу текстом\n\n💬 Напиши или надиктуй вопрос!",
        "additionalFields": { "parse_mode": "HTML" }
      },
      "id": "n-welcome",
      "name": "Send Welcome",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [980, 280],
      "credentials": { "telegramApi": { "id": "TELEGRAM_CRED_ID", "name": "Telegram Bot" } }
    },
