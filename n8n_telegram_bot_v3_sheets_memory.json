      "parameters": {
        "chatId": "={{ $json.chatId }}",
        "action": "typing",
        "additionalFields": {}
      },
      "id": "n-typing",
      "name": "Send Typing...",
      "type": "n8n-nodes-base.telegram",
      "typeVersion": 1.2,
      "position": [2800, 540],
      "credentials": { "telegramApi": { "id": "TELEGRAM_CRED_ID", "name": "Telegram Bot" } }
    },
    {
      "parameters": {
        "url": "https://api.anthropic.com/v1/messages",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "x-api-key",          "value": "={{ $env.ANTHROPIC_API_KEY }}" },
            { "name": "anthropic-version",   "value": "2023-06-01" },
            { "name": "content-type",        "value": "application/json" }
          ]
        },
        "sendBody": true,
        "contentType": "json",
        "body": "={{ JSON.stringify($('Build Claude Request').item.json.requestBody) }}",
        "options": {}
      },
      "id": "n-claude-api",
      "name": "Call Claude API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [3000, 540]
    },
    {
      "parameters": {
        "jsCode": "const claudeResp   = $input.first().json;\nconst buildData    = $('Build Claude Request').item.json;\n\n// Extract answer text\nlet answer = '';\nif (claudeResp.content?.length > 0) {\n  answer = claudeResp.content.map(c => c.text || '').join('');\n} else if (claudeResp.error) {\n  answer = `⚠️ Ошибка API: ${claudeResp.error.message}`;\n} else {\n  answer = 'Не удалось получить ответ. Попробуй ещё раз.';\n}\n\n// Telegram limit 4096 chars\nif (answer.length > 3800) {\n  answer = answer.substring(0, 3800) + '...\\n_[сокращено]_';\n}\n\nreturn [{\n  json: {\n    chatId:       buildData.chatId,\n    userQuestion: buildData.userQuestion,\n    answer\n  }\n}];"
      },
      "id": "n-format",
      "name": "Format Response",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [3200, 540]
    },
    {
      "parameters": {
        "documentId": { "__rl": true, "value": "YOUR_GOOGLE_SHEET_ID", "mode": "id" },
        "sheetName":  { "__rl": true, "value": "ChatHistory",          "mode": "name" },
        "columns": {
          "mappingMode": "defineBelow",
          "value": {
            "chatId":            "={{ $json.chatId }}",
            "timestamp":         "={{ $now.toISO() }}",
            "userMessage":       "={{ $json.userQuestion }}",
            "assistantMessage":  "={{ $json.answer }}"
          },
          "matchingColumns": [],
          "schema": [
            { "id": "chatId",           "displayName": "chatId",           "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "timestamp",        "displayName": "timestamp",        "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "userMessage",      "displayName": "userMessage",      "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true },
            { "id": "assistantMessage", "displayName": "assistantMessage", "required": false, "defaultMatch": false, "display": true, "type": "string", "canBeUsedToMatch": true }
          ]
        },
        "options": {}
      },
      "id": "n-save-sheets",
