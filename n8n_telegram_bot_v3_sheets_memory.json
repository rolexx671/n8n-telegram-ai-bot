      "id": "n-set-text",
      "name": "Set Text Data",
      "type": "n8n-nodes-base.set",
      "typeVersion": 3.4,
      "position": [1180, 660]
    },
    {
      "parameters": {
        "documentId": { "__rl": true, "value": "YOUR_GOOGLE_SHEET_ID", "mode": "id" },
        "sheetName":  { "__rl": true, "value": "ChatHistory",          "mode": "name" },
        "filtersUI":  { "values": [] },
        "options":    { "returnAllMatches": true }
      },
      "id": "n-read-sheets",
      "name": "Read History (Sheets)",
      "type": "n8n-nodes-base.googleSheets",
      "typeVersion": 4.4,
      "position": [2000, 540],
      "credentials": { "googleSheetsOAuth2Api": { "id": "GOOGLE_CRED_ID", "name": "Google Sheets" } }
    },
    {
      "parameters": {
        "jsCode": "// Get chatId and question from whichever branch was active\nlet chatId = '', userQuestion = '', username = '', isVoice = false;\ntry { chatId     = $('Set Voice Data').item.json.chatId;    } catch(e) {}\ntry { chatId     = chatId     || $('Set Text Data').item.json.chatId;    } catch(e) {}\ntry { userQuestion = $('Set Voice Data').item.json.chatInput;  } catch(e) {}\ntry { userQuestion = userQuestion || $('Set Text Data').item.json.chatInput; } catch(e) {}\ntry { username   = $('Set Voice Data').item.json.username;  } catch(e) {}\ntry { username   = username   || $('Set Text Data').item.json.username;  } catch(e) {}\ntry { isVoice    = $('Set Voice Data').item.json.isVoice;  } catch(e) {}\n\n// Get all rows from Sheets\nconst allRows = $input.all().map(i => i.json);\n\n// Filter by chatId, keep last 15 exchanges\nconst userRows = allRows\n  .filter(r => String(r.chatId) === String(chatId) && r.userMessage && r.assistantMessage)\n  .sort((a, b) => new Date(a.timestamp) - new Date(b.timestamp))\n  .slice(-15);\n\n// Build messages array for Claude API\nconst historyMessages = [];\nuserRows.forEach(row => {\n  historyMessages.push({ role: 'user',      content: String(row.userMessage) });\n  historyMessages.push({ role: 'assistant', content: String(row.assistantMessage) });\n});\n\nreturn [{ json: { chatId, userQuestion, username, isVoice, historyMessages } }];"
      },
      "id": "n-filter-history",
      "name": "Filter History",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2200, 540]
    },
    {
      "parameters": {
        "url": "https://api.tavily.com/search",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": { "parameters": [{ "name": "Content-Type", "value": "application/json" }] },
        "sendBody": true,
        "contentType": "json",
        "body": {
          "api_key": "={{ $env.TAVILY_API_KEY }}",
          "query": "={{ $json.userQuestion }}",
          "search_depth": "advanced",
          "include_answer": true,
          "include_raw_content": false,
          "max_results": 5
        },
        "options": {}
      },
      "id": "n-tavily",
      "name": "Tavily Web Search",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [2400, 540]
    },
    {
      "parameters": {
        "jsCode": "// All context from previous nodes\nconst filterData  = $('Filter History').item.json;\nconst searchData  = $input.first().json;\n\nconst { chatId, userQuestion, username, isVoice, historyMessages } = filterData;\n\n// Build search context for system prompt\nlet searchContext = '';\nif (searchData.answer) {\n  searchContext += `Краткий ответ из поиска: ${searchData.answer}\\n\\n`;\n}\nif (searchData.results?.length > 0) {\n  searchContext += 'Источники из интернета:\\n';\n  searchData.results.slice(0, 5).forEach((r, i) => {\n    const content = r.content ? r.content.substring(0, 450) : '';\n    searchContext += `\\n[${i+1}] ${r.title}\\nURL: ${r.url}\\n${content}\\n`;\n  });\n}\n\nconst systemMsg = `Ты — умный AI-ассистент в Telegram. Отвечаешь точно, чётко и полезно.\n\nПравила:\n- Отвечай на языке вопроса\n- Используй данные из поиска для актуальных фактов\n- Telegram Markdown: *жирный*, _курсив_, \\`код\\`, [текст](url)\n- Максимум 3000 символов в ответе\n- В конце укажи 1-2 источника если использовал поиск\n- Помни весь контекст разговора из истории${isVoice ? '\\n- Сообщение пришло голосом, текст был расшифрован' : ''}\n${ searchContext ? `\\n\\n=== АКТУАЛЬНЫЕ ДАННЫЕ ИЗ ИНТЕРНЕТА ===\\n${searchContext}=== КОНЕЦ ДАННЫХ ===` : '' }`;\n\n// Full messages array: history + current question\nconst messages = [\n  ...historyMessages,\n  { role: 'user', content: userQuestion }\n];\n\nreturn [{\n  json: {\n    chatId,\n    userQuestion,\n    username,\n    requestBody: {\n      model: 'claude-sonnet-4-6',\n      max_tokens: 2048,\n      temperature: 0.3,\n      system: systemMsg,\n      messages\n    }\n  }\n}];"
      },
      "id": "n-build-request",
      "name": "Build Claude Request",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [2600, 540]
    },
