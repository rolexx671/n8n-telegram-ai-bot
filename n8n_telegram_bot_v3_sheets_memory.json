      "parameters": { "respondWith": "json", "responseBody": "{ \"ok\": true }", "options": {} },
      "id": "n-resp-welcome",
      "name": "Response (welcome)",
      "type": "n8n-nodes-base.respondToWebhook",
      "typeVersion": 1.1,
      "position": [1180, 280]
    },
